# Sunucu portu (Railway otomatik ayarlar, değiştirme)
PORT=8080

# ════════════════════════════════════════
# TURN SUNUCUSU (Metered.ca veya Twilio)
# ════════════════════════════════════════
# Metered.ca ücretsiz tier için: https://www.metered.ca/stun-turn
# Kayıt ol → Dashboard → Credentials → aşağıdaki değerleri kopyala

TURN_URL=turn:openrelay.metered.ca:80
TURN_URL_TCP=turn:openrelay.metered.ca:443
TURN_USERNAME=openrelayproject
TURN_CREDENTIAL=openrelayproject

# ════════════════════════════════════════
# Twilio TURN (Ücretli, çok güvenilir)
# https://www.twilio.com/stun-turn
# ════════════════════════════════════════
# TURN_URL=turn:global.turn.twilio.com:3478?transport=udp
# TURN_URL_TCP=turn:global.turn.twilio.com:443?transport=tcp
# TURN_USERNAME=<twilio_account_sid>
# TURN_CREDENTIAL=<twilio_auth_token>
